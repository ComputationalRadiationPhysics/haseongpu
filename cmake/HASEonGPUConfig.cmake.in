@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(Threads)
find_dependency(alpaka CONFIG)
find_dependency(openPMD CONFIG)

if(@HASE_CONFIG_REQUIRES_MPI@)
    find_dependency(MPI COMPONENTS CXX)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/HASEonGPUTargets.cmake")

if(TARGET hase::hase_core AND NOT TARGET hase::core)
    add_library(hase::core ALIAS hase::hase_core)
endif()
