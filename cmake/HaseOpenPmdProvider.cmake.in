cmake_minimum_required(VERSION 3.24)
project(HaseOpenPmdProvider LANGUAGES C CXX)

include(FetchContent)

set(CMAKE_CXX_STANDARD 20)
set(CMAKE_POSITION_INDEPENDENT_CODE ON)
set(BUILD_SHARED_LIBS ON CACHE BOOL "Build shared provider libraries" FORCE)
set(BUILD_TESTING OFF CACHE BOOL "Disable third-party provider tests" FORCE)
set(CMAKE_INSTALL_RPATH "$ORIGIN;$ORIGIN/../lib" CACHE STRING "Provider install RPATH" FORCE)
set(CMAKE_INSTALL_RPATH_USE_LINK_PATH ON CACHE BOOL "Use provider link path RPATH" FORCE)
set(CMAKE_FIND_PACKAGE_PREFER_CONFIG TRUE)

set(HASE_PROVIDER_USE_ADIOS2 @HASE_OPENPMD_USE_ADIOS2@)
set(HASE_PROVIDER_USE_HDF5 @HASE_OPENPMD_USE_HDF5@)
set(HASE_PROVIDER_USE_SST @HASE_OPENPMD_USE_SST@)
set(HASE_PROVIDER_SUPERBUILD @HASE_OPENPMD_SUPERBUILD@)
set(HASE_PROVIDER_BUILD_PYTHON @HASE_OPENPMD_BUILD_PYTHON_BINDINGS@)
set(HASE_PROVIDER_USE_MPI @HASE_PROVIDER_USE_MPI@)

if(HASE_PROVIDER_USE_MPI)
    find_package(MPI COMPONENTS C CXX REQUIRED)
    set(HASE_PROVIDER_USE_MPI_VALUE ON)
else()
    set(HASE_PROVIDER_USE_MPI_VALUE OFF)
endif()

if(HASE_PROVIDER_USE_HDF5)
    find_package(HDF5 COMPONENTS C REQUIRED)
endif()

if(HASE_PROVIDER_USE_ADIOS2)
    find_package(ADIOS2 CONFIG REQUIRED)
    if(HASE_PROVIDER_USE_SST AND DEFINED ADIOS2_HAVE_SST AND NOT ADIOS2_HAVE_SST)
        message(FATAL_ERROR "HASE_OPENPMD_USE_SST=ON requires an ADIOS2 provider built with SST support")
    endif()
endif()

set(openPMD_USE_ADIOS2 ${HASE_PROVIDER_USE_ADIOS2} CACHE STRING "Enable openPMD ADIOS2" FORCE)
set(openPMD_USE_HDF5 ${HASE_PROVIDER_USE_HDF5} CACHE STRING "Enable openPMD HDF5" FORCE)
set(openPMD_HAVE_PKGCONFIG OFF CACHE BOOL "Disable openPMD pkg-config metadata" FORCE)
set(openPMD_USE_VERIFY OFF CACHE BOOL "Disable openPMD VERIFY checks" FORCE)
set(openPMD_SUPERBUILD ${HASE_PROVIDER_SUPERBUILD} CACHE BOOL "Allow openPMD internal helper dependencies" FORCE)
foreach(HASE_OPENPMD_INTERNAL_DEP IN ITEMS CATCH JSON TOML11 PYBIND11)
    set(openPMD_USE_INTERNAL_${HASE_OPENPMD_INTERNAL_DEP} ${HASE_PROVIDER_SUPERBUILD} CACHE BOOL "Use openPMD internal dependency" FORCE)
endforeach()
set(openPMD_USE_PYTHON ${HASE_PROVIDER_BUILD_PYTHON} CACHE BOOL "Build openPMD Python bindings" FORCE)
set(openPMD_BUILD_TESTING OFF CACHE BOOL "Disable openPMD tests" FORCE)
set(openPMD_BUILD_EXAMPLES OFF CACHE BOOL "Disable openPMD examples" FORCE)
set(openPMD_BUILD_CLI_TOOLS OFF CACHE BOOL "Disable openPMD CLI tools" FORCE)
set(openPMD_INSTALL ON CACHE BOOL "Install openPMD-api provider" FORCE)
set(openPMD_USE_MPI ${HASE_PROVIDER_USE_MPI_VALUE} CACHE STRING "Enable openPMD MPI" FORCE)

FetchContent_Declare(
    openPMD
    GIT_REPOSITORY "@HASE_OPENPMD_GIT_REPOSITORY@"
    GIT_TAG "@HASE_OPENPMD_GIT_TAG@"
)
FetchContent_MakeAvailable(openPMD)
