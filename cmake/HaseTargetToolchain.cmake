function(hase_collect_initial_target_toolchain_variables out_var)
    get_cmake_property(HASE_PRE_PROJECT_CACHE_VARIABLES CACHE_VARIABLES)
    set(HASE_INITIAL_TARGET_TOOLCHAIN_VARIABLES "")
    foreach(
        HASE_PRE_PROJECT_CACHE_VARIABLE
        IN
        LISTS HASE_PRE_PROJECT_CACHE_VARIABLES
    )
        if(
            HASE_PRE_PROJECT_CACHE_VARIABLE
                IN_LIST
                HASE_FORWARDED_TARGET_TOOLCHAIN_VARIABLES
        )
            list(
                APPEND
                HASE_INITIAL_TARGET_TOOLCHAIN_VARIABLES
                "${HASE_PRE_PROJECT_CACHE_VARIABLE}"
            )
        endif()
    endforeach()
    set(${out_var} "${HASE_INITIAL_TARGET_TOOLCHAIN_VARIABLES}" PARENT_SCOPE)
endfunction()
