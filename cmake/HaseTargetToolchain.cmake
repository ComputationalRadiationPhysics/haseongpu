include_guard(GLOBAL)

function(hase_extract_cmake_definition_names argument_string out_var)
    string(
        REGEX MATCHALL
        "-D[^:= \t\r\n]+(:[^= \t\r\n]+)?="
        HASE_CMAKE_DEFINITIONS
        "${argument_string}"
    )
    set(HASE_CMAKE_DEFINITION_NAMES "")
    foreach(HASE_CMAKE_DEFINITION IN LISTS HASE_CMAKE_DEFINITIONS)
        string(
            REGEX REPLACE
            "^-D([^:=]+)(:[^=]+)?=$"
            "\\1"
            HASE_CMAKE_DEFINITION_NAME
            "${HASE_CMAKE_DEFINITION}"
        )
        list(APPEND HASE_CMAKE_DEFINITION_NAMES "${HASE_CMAKE_DEFINITION_NAME}")
    endforeach()
    list(REMOVE_DUPLICATES HASE_CMAKE_DEFINITION_NAMES)
    set(${out_var} "${HASE_CMAKE_DEFINITION_NAMES}" PARENT_SCOPE)
endfunction()

